rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isManager() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isManager();
      allow create: if isOwner(userId)
        && request.resource.data.email == request.auth.token.email;
      allow update: if (
        isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
      ) || isManager();
      allow delete: if isManager();

      // Baskets
      match /baskets/{basketId} {
        allow read: if isOwner(userId) || isManager();
        allow create: if isOwner(userId) && request.resource.data.ownerUid == userId;
        allow update: if isOwner(userId) || isManager();
        allow delete: if isManager();
      }
    }

    // Product catalog — readable by all signed-in users, writable only by manager
    match /productCatalog/{productId} {
      allow read: if signedIn();
      allow create, update, delete: if isManager();
    }

    // Sync status — manager only
    match /syncStatus/{syncId} {
      allow read, write: if isManager();
    }

    // Pending baskets — imported from mishnatyosef.org, linked on first login
    // keyed by email (lowercased). Manager writes, owner reads.
    match /pendingBaskets/{emailKey} {
      allow read: if signedIn()
        && request.auth.token.email.lower() == emailKey;
      allow read, write: if isManager();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
