rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isManager() {
      return signedIn()
        && request.auth.token.email in [
          "manager@example.com"
        ];
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role in ["customer", "admin"]
        && (
          request.resource.data.role == "customer"
          || isManager()
        );

      allow read: if isOwner(userId) || isManager();

      allow update: if (
        isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["name", "email", "lastLoginAt"])
        && request.resource.data.email == request.auth.token.email
      ) || isManager();

      allow delete: if isManager();

      match /baskets/{basketId} {
        allow create: if isOwner(userId)
          && request.resource.data.ownerUid == userId;

        allow read: if isOwner(userId) || isManager();
        allow update: if isOwner(userId) || isManager();
        allow delete: if isManager();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
